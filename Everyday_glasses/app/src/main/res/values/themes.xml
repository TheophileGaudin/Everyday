<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.Everyday_glasses" parent="Theme.AppCompat.NoActionBar">
        <item name="android:windowBackground">@color/black</item>
        <item name="android:colorBackground">@color/black</item>
        <!-- Prevent system keyboard from appearing -->
        <item name="android:windowSoftInputMode">stateAlwaysHidden|adjustNothing</item>
        <item name="android:imeOptions">flagNoExtractUi|flagNoFullscreen</item>
    </style>
</resources>
